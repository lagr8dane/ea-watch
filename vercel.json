{
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/stub",                          "destination": "/stub.html" },
    { "source": "/contact",                       "destination": "/contact.html" },
    { "source": "/ea",                            "destination": "/ea.html" },
    { "source": "/challenge",                     "destination": "/challenge.html" },
    { "source": "/config",                        "destination": "/config.html" },
    { "source": "/chains",                        "destination": "/chain-builder.html" },
    { "source": "/action-log",                    "destination": "/action-log.html" },
    { "source": "/tasks",                         "destination": "/tasks.html" },
    { "source": "/api/tasks/:id",                 "destination": "/api/tasks" },
    { "source": "/api/chains/:id/steps/:stepId",  "destination": "/api/chains" },
    { "source": "/api/chains/:id/steps",          "destination": "/api/chains" },
    { "source": "/api/chains/:id",                "destination": "/api/chains" },
    { "source": "/api/chain-execute/log",         "destination": "/api/chain-execute" },
    { "source": "/",                              "destination": "/api/tap" }
  ]
}
