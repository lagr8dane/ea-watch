# Turso database
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Alert delivery
ALERT_SENDGRID_KEY=your-sendgrid-api-key
ALERT_FROM_EMAIL=alerts@yourdomain.com

# Dev stub — set to 'true' in dev only, never in production
ENABLE_STUB=false

# App
APP_URL=https://tap.yourdomain.com
NODE_ENV=development

# Optional — not wired yet; see README “Future integrations” for Yelp / Places / Foursquare ideas
# YELP_API_KEY=
# GOOGLE_PLACES_API_KEY=
