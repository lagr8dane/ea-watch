# Turso database
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Alert delivery
ALERT_SENDGRID_KEY=your-sendgrid-api-key
ALERT_FROM_EMAIL=alerts@yourdomain.com

# Dev stub — set to 'true' in dev only, never in production
ENABLE_STUB=false

# App
APP_URL=https://tap.yourdomain.com
NODE_ENV=development

# Optional — Interest radar “Find places” mode (Google Places API New)
# GOOGLE_PLACES_API_KEY=

# Optional — future / not wired
# YELP_API_KEY=
